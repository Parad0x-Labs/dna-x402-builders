{
  "name": "dna-x402-builders",
  "version": "0.1.0-public-beta",
  "description": "Public builder SDK, docs, and examples for integrating with the DNA x402 payment rail.",
  "type": "module",
  "private": false,
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "acceptance": "npm run build && npm test",
    "examples:buyer": "tsx examples/buyer-agent-ts/src/index.ts",
    "examples:seller": "tsx examples/seller-paid-api-ts/src/index.ts",
    "examples:builder-fee": "tsx examples/builder-monetized-agent-ts/src/index.ts",
    "examples:webhook": "tsx examples/webhook-receiver-ts/src/index.ts",
    "examples:receipt": "tsx examples/receipt-verifier-ts/src/index.ts",
    "examples:agent-builder": "tsx examples/agent-builder-ts/src/index.ts",
    "examples:paper-agent": "tsx examples/paper-agent-ts/src/index.ts",
    "examples:copy-settings": "tsx examples/copy-settings-ts/src/index.ts",
    "examples:alpha": "tsx examples/alpha-monetization-ts/src/index.ts",
    "examples:direct-split": "tsx examples/direct-split-demo-ts/src/index.ts",
    "examples:paradox-signal-reseller": "tsx examples/paradox-signal-reseller-ts/src/index.ts",
    "examples:paradox-sports-telegram": "tsx examples/paradox-sports-feed-telegram-ts/src/index.ts",
    "examples:paradox-dashboard": "tsx examples/paradox-signal-dashboard-ts/src/index.ts",
    "examples:paradox-result-webhook": "tsx examples/paradox-result-update-webhook-ts/src/index.ts",
    "examples:templates": "tsx examples/agent-templates/src/index.ts",
    "examples:community": "tsx examples/community-agents/src/index.ts",
    "examples:meme-casino": "tsx examples/meme-casino-agents/src/index.ts",
    "examples:social-x": "tsx examples/social-x-agents/src/index.ts",
    "examples:telegram-launcher": "tsx launchers/telegram/src/index.ts",
    "examples:discord-launcher": "tsx launchers/discord/src/index.ts",
    "examples:live-solana-devnet": "tsx examples/live-solana-devnet/src/index.ts",
    "acceptance:templates:devnet": "vitest run tests/agent-template-gallery.test.ts tests/community-agent-templates.test.ts tests/meme-casino-templates.test.ts tests/social-x-templates.test.ts tests/template-devnet-acceptance.test.ts",
    "acceptance:community-agents": "vitest run tests/community-agent-templates.test.ts tests/community-launcher-commands.test.ts",
    "acceptance:paradox-signals": "vitest run tests/paradox-signal-licensing.test.ts",
    "acceptance:telegram-launcher": "vitest run tests/telegram-launcher.test.ts",
    "acceptance:discord-launcher": "vitest run tests/discord-launcher.test.ts",
    "acceptance:live:solana-devnet": "tsx examples/live-solana-devnet/src/index.ts",
    "examples:all": "npm run examples:buyer && npm run examples:seller && npm run examples:builder-fee && npm run examples:webhook && npm run examples:receipt && npm run examples:agent-builder && npm run examples:paper-agent && npm run examples:copy-settings && npm run examples:alpha && npm run examples:direct-split && npm run examples:paradox-signal-reseller && npm run examples:paradox-sports-telegram && npm run examples:paradox-dashboard && npm run examples:paradox-result-webhook && npm run examples:templates && npm run examples:community && npm run examples:meme-casino && npm run examples:social-x && npm run examples:telegram-launcher && npm run examples:discord-launcher"
  },
  "keywords": [
    "x402",
    "payments",
    "agents",
    "api-commerce",
    "solana",
    "usdc",
    "builder-sdk"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
